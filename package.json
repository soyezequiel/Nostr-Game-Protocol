{
  "name": "nostr-game-protocol",
  "version": "0.6.0",
  "description": "SDK de NGP (Nostr Games Protocol) y NGE (Nostr Game Escrow): wire canónico compartido tienda ⇄ juegos + cliente NGE y capa de firma NGP del lado juego.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soyezequiel/Nostr-Game-Protocol.git"
  },
  "type": "module",
  "files": [
    "dist",
    "src",
    "vectors"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nge": {
      "types": "./dist/nge.d.ts",
      "default": "./dist/nge.js"
    },
    "./nge-core": {
      "types": "./dist/nge-core.d.ts",
      "default": "./dist/nge-core.js"
    },
    "./nge-client": {
      "types": "./dist/nge-client.d.ts",
      "default": "./dist/nge-client.js"
    },
    "./ngp": {
      "types": "./dist/ngp.d.ts",
      "default": "./dist/ngp.js"
    },
    "./ngp-core": {
      "types": "./dist/ngp-core.d.ts",
      "default": "./dist/ngp-core.js"
    },
    "./bal": {
      "types": "./dist/bal.d.ts",
      "default": "./dist/bal.js"
    },
    "./bal-core": {
      "types": "./dist/bal-core.d.ts",
      "default": "./dist/bal-core.js"
    },
    "./bal-client": {
      "types": "./dist/bal-client.d.ts",
      "default": "./dist/bal-client.js"
    },
    "./bal-launcher": {
      "types": "./dist/bal-launcher.d.ts",
      "default": "./dist/bal-launcher.js"
    },
    "./bal-nip46": {
      "types": "./dist/bal-nip46.d.ts",
      "default": "./dist/bal-nip46.js"
    },
    "./bal-web": {
      "types": "./dist/bal-web.d.ts",
      "default": "./dist/bal-web.js"
    },
    "./vectors/nge-test-vectors.json": "./vectors/nge-test-vectors.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "gen:vectors": "node scripts/gen-vectors.cjs"
  },
  "peerDependencies": {
    "nostr-tools": "^2.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "nostr-tools": "^2.23.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
